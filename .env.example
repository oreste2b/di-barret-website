# Di Barret — backend env vars
# Set these in Vercel: Project → Settings → Environment Variables
# Local dev: copy this file to .env.local and fill in values, then run `vercel env pull`.

# Resend API key (generate at https://resend.com/api-keys with "Sending access" scope)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender address. Must match a domain verified in Resend.
# Format: "Display Name <email@dibarret.dk>"
LEAD_FROM="Di Barret <kontakte@dibarret.dk>"

# Where lead notifications are delivered
LEAD_NOTIFY_TO=kontakte@dibarret.dk

# Optional. Reply-To header on the auto-reply that goes to the lead.
# Defaults to LEAD_NOTIFY_TO if unset.
LEAD_REPLY_TO=kontakte@dibarret.dk
